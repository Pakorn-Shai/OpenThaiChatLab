# Required for production/server-managed API key mode.
TYPHOON_API_KEY=

# Optional overrides.
TYPHOON_BASE_URL=https://api.opentyphoon.ai/v1

# Local runtime settings.
HOST=127.0.0.1
PORT=5000
FLASK_DEBUG=false

# Upload limits.
MAX_UPLOAD_BYTES=31457280
MAX_ASR_FILE_BYTES=26214400
MAX_OCR_FILE_BYTES=10485760
OCR_BATCH_SIZE=5
OCR_BATCH_WAIT_SECONDS=3

# Chat generation settings.
CHAT_TEMPERATURE=0.6
CHAT_TOP_P=0.6
CHAT_MAX_COMPLETION_TOKENS=2048
